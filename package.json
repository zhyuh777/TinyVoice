{
  "name": "tinyvoice",
  "productName": "TinyVoice",
  "version": "1.0.0",
  "description": "TinyVoice - 智能语音朗读器，支持多格式电子书导入与神经语音合成",
  "main": "main.js",
  "scripts": {
    "tauri:dev": "cd src && python3 -m http.server 1420 & sleep 1 && cd ../src-tauri && cargo build && ../target/debug/tinyvoice",
    "tauri:build": "cd src-tauri && cargo build --release && cp ../src/*.html ../src/*.js ../src/*.css ../src-tauri/target/release/bundle/macos/TinyVoice.app/Contents/Resources/ && create-dmg --dmg-title=TinyVoice --overwrite --no-code-sign src-tauri/target/release/bundle/macos/TinyVoice.app ../dist/"
  },
  "build": {
    "appId": "com.tinyvoice.app",
    "productName": "TinyVoice",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "extraResources": [
        {
          "from": ".venv",
          "to": ".venv",
          "filter": [
            "**/*",
            "!lib/python*/site-packages/pip/**",
            "!**/__pycache__/**",
            "!**/*.dist-info/**"
          ]
        }
      ]
    },
    "win": {
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      "icon": "assets/icon-256.png"
    },
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "pdf-parser.js",
      "edge-tts.js",
      "src/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "author": "TinyVoice"
}

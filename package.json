{
  "name": "tinyvoice",
  "productName": "TinyVoice",
  "version": "1.0.0",
  "description": "TinyVoice - 智能语音朗读器，支持多格式电子书导入与神经语音合成",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.tinyvoice.app",
    "productName": "TinyVoice",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "extraResources": [
        {
          "from": ".venv",
          "to": ".venv",
          "filter": ["**/*", "!lib/python*/site-packages/pip/**", "!**/__pycache__/**", "!**/*.dist-info/**"]
        }
      ]
    },
    "win": {
      "target": {
        "target": "nsis",
        "arch": ["x64"]
      },
      "icon": "assets/icon-256.png"
    },
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "pdf-parser.js",
      "src/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "electron-builder": "^25.1.8",
    "electron": "^33.4.11"
  },
  "author": "TinyVoice"
}

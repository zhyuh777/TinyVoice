{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TinyVoice",
  "version": "1.0.0",
  "identifier": "com.tinyvoice.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TinyVoice",
        "width": 1000,
        "height": 640,
        "minWidth": 780,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../src/**/*",
      "binaries/edge-tts"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist"
    }
  }
}
